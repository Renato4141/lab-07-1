<%= render "shared/error_messages", object: pet %>

<%= form_with(model: pet) do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :species, class: "form-label" %>
    <%= f.text_field :species, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :breed, class: "form-label" %>
    <%= f.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :owner_id, "Owner", class: "form-label" %>
    <%= f.collection_select :owner_id, Owner.all, :id, :first_name, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :date_of_birth, class: "form-label" %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :weight, class: "form-label" %>
    <%= f.number_field :weight, step: 0.1, class: "form-control" %>
  </div>

  <% if pet.persisted? && pet.photo.attached? %>
    <div class="mb-3">
      <label class="form-label">Current photo</label><br>

      <%= image_tag pet.photo,
            width: 100,
            class: "img-thumbnail" %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :photo, class: "form-label" %>

    <%= f.file_field :photo,
          class: "form-control",
          accept: "image/jpeg,image/png,image/webp" %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>